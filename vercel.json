{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/$1"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "/$1"
      }
    }
  ]
}
